# Feishu App credentials
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_HTTP_TIMEOUT_SEC=20

# Optional: allow only these Feishu open_id users (comma-separated)
ALLOWED_USER_IDS=ou_xxx

# Reply backend preference (Codex CLI first)
USE_CODEX_CLI=true
CODEX_CLI_CMD=codex
CODEX_WORKDIR=/Users/cn/Workspace
CODEX_PROJECT_ROOT=/Users/cn/Workspace
CODEX_SANDBOX=workspace-write
CODEX_ADD_DIRS=
CODEX_TIMEOUT_SEC=0
CODEX_MODEL=
CODEX_RESUME_ENABLED=true
CODEX_RETRY_FRESH_ON_TIMEOUT=true
CODEX_THREAD_STATE_FILE=.state/codex_threads.json
CODEX_MEMORY_ENABLED=true
CODEX_MEMORY_TURNS=6
CODEX_MEMORY_STATE_FILE=.state/codex_memory.json
CODEX_STATUS_UPDATE_ENABLED=true
CODEX_STATUS_POLL_SEC=3
CODEX_STATUS_FOLLOWUP_SEC=30

# De-duplicate Feishu retried events/messages
DEDUPE_TTL_SEC=900
DEDUPE_MAX_IDS=2000

# Daily auto report schedule/config
DAILY_REPORT_HOUR=22
DAILY_REPORT_MINUTE=30
DAILY_REPORT_DATE_MODE=today
DAILY_REPORT_SEND_OPEN_ID=
DAILY_REPORT_WORKSPACE_ROOT=/Users/cn/Workspace
DAILY_REPORT_SESSIONS_DIR=~/.codex/sessions
DAILY_REPORT_CURRENT_WORKDIR=/Users/cn/Workspace/feishu-bot-bridge
DAILY_REPORT_SCOPE=codex_snapshot,work_snapshot

# Opportunity scout schedule/config
SCOUT_REPORT_HOUR=8
SCOUT_REPORT_MINUTE=0
SCOUT_SEND_OPEN_ID=
SCOUT_CODEX_MODEL=
SCOUT_CODEX_TIMEOUT_SEC=900
SCOUT_TARGET_MARKET=global_en
SCOUT_REPORT_LANGUAGE=zh-CN
SCOUT_FALLBACK_POLICY=send_low_confidence
SCOUT_NOVELTY_LOOKBACK_DAYS=3
SCOUT_NOVELTY_MAX_PENALTY=0.7
SCOUT_MIN_PAY_SIGNAL=3
SCOUT_MIN_COMMERCIAL_SCORE=3.0
SCOUT_HUNT_ROUNDS=1
SCOUT_OUTPUT_DIR=/Users/cn/Workspace/feishu-bot-bridge/reports/opportunity-scout
SCOUT_JOB_LOCK_FILE=/Users/cn/Workspace/feishu-bot-bridge/.state/opportunity_scout_job.lock
SCOUT_WATCHDOG_INTERVAL_SEC=360
SCOUT_WATCHDOG_GRACE_MIN=20
SCOUT_WATCHDOG_CODEX_TIMEOUT_SEC=1800
SCOUT_WATCHDOG_STATE_FILE=/Users/cn/Workspace/feishu-bot-bridge/.state/opportunity_scout_watchdog.json

# Xiaohongshu AI blogger daily ops
XHS_REPORT_HOUR=9
XHS_REPORT_MINUTE=0
XHS_SEND_OPEN_ID=
XHS_CODEX_MODEL=
XHS_CODEX_TIMEOUT_SEC=900
XHS_NICHE=AI提效
XHS_TARGET_PERSONA=一二线城市职场人
XHS_MONETIZATION_GOAL=咨询线索
XHS_BRAND_VOICE=务实、直接、少鸡汤
XHS_PUBLISH_WINDOWS=12:30,18:30,21:30
XHS_MAX_POSTS_PER_DAY=3
XHS_MAX_COMMENTS_PER_DAY=20
XHS_COMMENTS_PER_TOPIC=2
XHS_SIGNAL_MIN_COUNT=12
XHS_FALLBACK_POLICY=send_low_confidence
XHS_OUTPUT_DIR=/Users/cn/Workspace/feishu-bot-bridge/reports/xhs-ai-blogger
XHS_COVER_ENABLED=true
XHS_COVER_OUTPUT_DIR=/Users/cn/Workspace/feishu-bot-bridge/reports/xhs-ai-blogger/assets
XHS_COVER_TEMPLATE=minimal_v1
XHS_COVER_SCRIPT=/Users/cn/Workspace/feishu-bot-bridge/scripts/xhs_cover_generator.py
XHS_COVER_PROVIDER=auto
XHS_COVER_SKILL_PRIMARY=xiaohongshu-images
XHS_COVER_SKILL_SECONDARY=image-generation-mcp
XHS_COVER_SKILL_REQUIRED=false
XHS_COVER_SKILL_FALLBACK_LOCAL=true
XHS_COVER_SKILL_TIMEOUT_SEC=1200
XHS_CONTENT_SKILL_NAME=xiaohongshu-content-generator
XHS_CONTENT_SKILL_PATH=/Users/cn/.codex/skills/xiaohongshu-content-generator/SKILL.md
XHS_CONTENT_SKILL_REQUIRED=false
XHS_JOB_LOCK_FILE=/Users/cn/Workspace/feishu-bot-bridge/.state/xhs_ai_blogger_job.lock
XHS_EXECUTOR_ENABLED=false
XHS_EXECUTOR_MODE=queue_only
XHS_EXECUTOR_REQUIRE_APPROVAL=true
XHS_EXECUTOR_AUTO_APPROVE=false
XHS_EXECUTOR_SCRIPT=/Users/cn/Workspace/feishu-bot-bridge/scripts/xhs_auto_executor.py
XHS_PUBLISH_DRIVER=auto
XHS_POST_TO_XHS_SCRIPT=/Users/cn/.codex/skills/post-to-xhs/scripts/publish_pipeline.py
XHS_POST_TO_XHS_HEADLESS=true
XHS_POST_TO_XHS_AUTO_PUBLISH=true
XHS_POST_TO_XHS_MODE=image-text
XHS_POST_TO_XHS_ACCOUNT=
# XHS_EXECUTOR_HOOK_TIMEOUT_SEC=
XHS_EXECUTION_OUTPUT_DIR=/Users/cn/Workspace/feishu-bot-bridge/reports/xhs-ai-blogger/executions
XHS_AUTH_MODE=web_session
XHS_SESSION_MAX_AGE_HOURS=72
XHS_SESSION_CHECK_REQUIRED=false
XHS_HOOK_SESSION_CHECK_CMD=
XHS_RELOGIN_HINT=./scripts/xhs_web_session_auth.sh login --account-id <xhs_account_id> --username <login_name> --url https://creator.xiaohongshu.com/new/home
XHS_HOOK_PUBLISH_CMD=python3 scripts/xhs_web_operator.py publish --storage-state {storage_state} --entry-url https://creator.xiaohongshu.com/new/home --publish-mode image_note --image-strategy text_card --title {title} --content {content} --images {images_csv} --topics {tags_csv} --headful --keep-open-on-fail --hold-seconds-on-fail 1800
XHS_HOOK_COMMENT_CMD=python3 scripts/xhs_web_operator.py comment --storage-state {storage_state} --browse-url https://www.xiaohongshu.com/explore --topic {topic} --comment {comment} --headful
XHS_ACCOUNT_KEYCHAIN_SERVICE=feishu-bot-bridge.xhs.account
XHS_ACCOUNT_KEYCHAIN_ACCOUNT=default
XHS_PYTHON_BIN=/opt/anaconda3/bin/python3

# OpenAI / LLM config (optional, if you want model replies)
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-5-mini
