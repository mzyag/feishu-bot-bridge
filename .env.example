# Feishu App credentials
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_HTTP_TIMEOUT_SEC=20

# Optional: allow only these Feishu open_id users (comma-separated)
ALLOWED_USER_IDS=ou_xxx

# Reply backend preference (Codex CLI first)
USE_CODEX_CLI=true
CODEX_CLI_CMD=codex
CODEX_WORKDIR=/Users/cn/Workspace
CODEX_PROJECT_ROOT=/Users/cn/Workspace
CODEX_SANDBOX=workspace-write
CODEX_ADD_DIRS=
CODEX_TIMEOUT_SEC=0
CODEX_MODEL=
CODEX_RESUME_ENABLED=true
CODEX_RETRY_FRESH_ON_TIMEOUT=true
CODEX_THREAD_STATE_FILE=.state/codex_threads.json
CODEX_MEMORY_ENABLED=true
CODEX_MEMORY_TURNS=6
CODEX_MEMORY_STATE_FILE=.state/codex_memory.json
CODEX_STATUS_UPDATE_ENABLED=true
CODEX_STATUS_POLL_SEC=3
CODEX_STATUS_FOLLOWUP_SEC=30

# De-duplicate Feishu retried events/messages
DEDUPE_TTL_SEC=900
DEDUPE_MAX_IDS=2000

# Daily auto report schedule/config
DAILY_REPORT_HOUR=22
DAILY_REPORT_MINUTE=30
DAILY_REPORT_DATE_MODE=today
DAILY_REPORT_SEND_OPEN_ID=
DAILY_REPORT_WORKSPACE_ROOT=/Users/cn/Workspace
DAILY_REPORT_SESSIONS_DIR=~/.codex/sessions
DAILY_REPORT_CURRENT_WORKDIR=/Users/cn/Workspace/feishu-bot-bridge
DAILY_REPORT_SCOPE=codex_snapshot,work_snapshot

# Opportunity scout schedule/config
SCOUT_REPORT_HOUR=8
SCOUT_REPORT_MINUTE=0
SCOUT_SEND_OPEN_ID=
SCOUT_CODEX_MODEL=
SCOUT_CODEX_TIMEOUT_SEC=900
SCOUT_TARGET_MARKET=global_en
SCOUT_REPORT_LANGUAGE=zh-CN
SCOUT_FALLBACK_POLICY=send_low_confidence
SCOUT_OUTPUT_DIR=/Users/cn/Workspace/feishu-bot-bridge/reports/opportunity-scout
SCOUT_JOB_LOCK_FILE=/Users/cn/Workspace/feishu-bot-bridge/.state/opportunity_scout_job.lock
SCOUT_WATCHDOG_INTERVAL_SEC=360
SCOUT_WATCHDOG_GRACE_MIN=20
SCOUT_WATCHDOG_CODEX_TIMEOUT_SEC=1800
SCOUT_WATCHDOG_STATE_FILE=/Users/cn/Workspace/feishu-bot-bridge/.state/opportunity_scout_watchdog.json

# OpenAI / LLM config (optional, if you want model replies)
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-5-mini
